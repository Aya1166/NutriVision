@page "/"

<div class="hero-section">

    <div class="hero-content">

        <h1>
            NutriVision
        </h1>

        <p>
            Smart Nutrition & Recipe Analytics Platform
        </p>

        <div class="hero-buttons">

            <a href="/recipes" class="primary-btn">
                Explore Recipes
            </a>

            <a href="/analytics" class="secondary-btn">
                View Analytics
            </a>

        </div>

    </div>

</div>

<div class="features-section">

    <div class="feature-card">

        <div class="icon">
            🍽️
        </div>

        <h3>Recipe Management</h3>

        <p>
            Create and organize intelligent recipes
            with advanced nutritional tracking.
        </p>

    </div>

    <div class="feature-card">

        <div class="icon">
            📊
        </div>

        <h3>Analytics Dashboard</h3>

        <p>
            Visualize recipe statistics, cuisine trends,
            and calorie insights dynamically.
        </p>

    </div>

    <div class="feature-card">

        <div class="icon">
            🧠
        </div>

        <h3>Smart Nutrition Insights</h3>

        <p>
            Automatically detect balanced meals,
            high protein recipes, and more.
        </p>

    </div>

</div>

<div class="stats-section">

    <div class="stat-box">
        <h2>100%</h2>
        <p>Modern Blazor Architecture</p>
    </div>

    <div class="stat-box">
        <h2>EF Core</h2>
        <p>SQL Database & LINQ Analytics</p>
    </div>

    <div class="stat-box">
        <h2>AI Style</h2>
        <p>Nutrition Intelligence System</p>
    </div>

</div>